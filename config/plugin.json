{
  "Q": {
		"pluginInfo": {
			"AI": {
				"version": "0.1",
				"compatible": "0.1",
				"requires": {
					"Q": "1.0",
					"Users": "1.0",
					"Streams": "1.0",
					"Websites": "1.0"
				},
				"permissions": [],
				"connections": ["Users", "Streams", "Websites"]
			}
		},
		"handlersBeforeEvent": {
			"Q/responseExtras": ["AI/before/Q_responseExtras"],
			"Streams/image/save": ["AI/before/Streams_image_save"]
		},
		"handlersAfterEvent": {
			/* "Streams/create/Streams/image": ["AI/after/Streams_create_Streams_image"] */
		},
		"routes@start": {
			"AI/stream/command": {
				"module": "AI",
				"action": "stream/command"
			}
		},
		"routes@end": {
			
		},
		"routes": {
			  "AI/webhook/:type/:task": {"module": "AI", "action": "webhook"}
		},
		"web": {

		},
		"javascript": {

		},
		"text": {

		},
		"images": {

		}
	},
	"Users": {

	},
	"Streams": {
		"commands": {
			"AI": {
				"image/generate": {
					"handler": "AI/commands/imageGenerate",
					"routing": "background"
				},
				"tool/generate": {
					"handler": "AI/commands/toolGenerate",
					"routing": "veto"
				},
				"slide/generate": {
					"routing": "veto",
					"handler": "AI.commands.slideGenerate",
					"description": "AI-composed HTML slide with images from web search"
				}
			}
		}
	},
	"AI": {
		"observations": {
			"AI": "observations.json"
		},
		"images": {
			"batch": 2,
			"titles": {
				"generate": true
			}
		},
		"image": {
			"default": "openai",
			"providers": {
				"openai": {"model": "dall-e-3"},
				"aws": {"model": "stability.stable-diffusion-xl-v0"},
				"google": {"background": "transparent"}
			}
		},
		"llm": {
			"default": "anthropic-direct",
			"routes": {
				"smart": "anthropic-direct",
				"fast": "openai-mini",
				"search": "anthropic-direct"
			},
			"providers": {
				"anthropic-direct": {
					"class": "Anthropic",
					"config": {"model": "claude-3-5-sonnet-20241022"}
					},
					"openai-mini": {
					"class": "Openai",
					"config": {"model": "gpt-4o-mini"}
				}
			}
		},
		"schema": "Media/config/messages.schema.json",
		"voice": {
			"provider": null,
			"key": null,
			"_providers": "elevenlabs | openai | google \u2014 null disables voice synthesis"
		},
		"speech": {
			"provider": null,
			"_providers": "deepgram | browser | null \u2014 client-side STT adapter. null/browser uses native SpeechRecognition; deepgram routes mic audio through the /Q socket to AI/Transcription/DeepgramStream on the server. Heuristic: if null but AI/deepgram/key is set, treated as 'deepgram'.",
			"sampleRate": 16000,
			"chunkMs": 100
		},
		"transcription": {
			"provider": null,
			"_providers": "deepgram | assemblyai \u2014 null disables server-side transcription (falls back to browser WebSpeech)",
			"deepgram": {
				"key": null,
				"endpointing": 300,
				"interimResults": true
			},
			"assemblyai": {
				"key": null,
				"wordBoost": null
			}
		}
	}
}
